# DO NOT REMOVE THIS - Needed for Node.js to run on cPanel
PassengerAppRoot "/home/vdranjxy/comrades-master"
PassengerBaseURI "/"
PassengerAppType node
PassengerStartupFile server.js

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 0. Force HTTPS (prevents protocol mismatch on mobile)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 0b. Redirect www to non-www (canonical domain)
  RewriteCond %{HTTP_HOST} ^www\.comrades360\.shop$ [NC]
  RewriteRule ^ https://comrades360.shop%{REQUEST_URI} [L,R=301]

  # 1. EXCLUDE API and Socket.IO FROM SPA REDIRECTS (Passenger handles these)
  RewriteCond %{REQUEST_URI} ^/api [OR]
  RewriteCond %{REQUEST_URI} ^/socket.io [OR]
  RewriteCond %{REQUEST_URI} ^/uploads
  RewriteRule .* - [L]

  # 2. React Router SPA Routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
