<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. Route API requests - Commented out manual proxy to port 5004 (Port Mismatch)
  # In cPanel/Passenger, the routing is handled automatically.
  # RewriteRule ^api/(.*)$ http://localhost:5004/api/$1 [P,L]

  # 2. React Router SPA Routing
  # If the requested resource is not a file or directory, serve index.html
  # BUT exclude /api requests so they reach the Node.js backend
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_URI} !^/api
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
