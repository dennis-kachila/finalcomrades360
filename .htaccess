# Keep Passenger directives as fallback
PassengerAppRoot "/home/vdranjxy/comrades-master"
PassengerBaseURI "/"
PassengerAppType node
PassengerStartupFile server.js

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Proxy API, Socket.IO, Uploads to PM2 Node.js app on port 5000
  RewriteCond %{REQUEST_URI} ^/api [OR]
  RewriteCond %{REQUEST_URI} ^/socket.io [OR]
  RewriteCond %{REQUEST_URI} ^/uploads
  RewriteRule ^(.*)$ http://127.0.0.1:5000/$1 [P,L]

  # 0. Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 0b. Redirect www to non-www (canonical domain)
  RewriteCond %{HTTP_HOST} ^www\.comrades360\.shop$ [NC]
  RewriteRule ^ https://comrades360.shop%{REQUEST_URI} [L,R=301]

  # 2. React Router SPA Routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>
